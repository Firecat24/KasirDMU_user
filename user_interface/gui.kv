                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                id: tombol_dashboard
                text: 'Dashboard'
                font_size: 12
                size_hint_x: None
                width: 100
                on_release: app.change_screen('dashboard',"right")

            Button:
                id: tombol_add_golongan
                text: 'Insert Golongan Obat'
                font_size: 12
                size_hint_x: None
                width: 150
                on_release: app.change_screen('insert_golongan_obat',"left")

            Button:
                id: tombol_edit_golongan
                text: 'Edit Golongan Obat'
                font_size: 12
                size_hint_x: None
                width: 150
                on_release: root.edit_data_golongan_obat()

            Button:
                id: tombol_hapus_golongan
                text: 'Hapus Golongan Obat'
                font_size: 12
                size_hint_x: None
                width: 150
                on_release: root.hapus_terpilih()

        Label:
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, 1

            text: 'DATA GOLONGAN OBAT'
            font_size: 30
            size_hint_y: None
            height: 40
            halign: 'center'
            valign: 'middle'
            color: 0, 0, 0, 1
            text_size: self.size

        BoxLayout:
            id: table_container_golongan
            orientation: "vertical"
            size_hint: 1, 1

            ScrollView:
                id: scroll_golongan
                do_scroll_x: True
                do_scroll_y: True

                GridLayout:
                    id: grid_golongan
                    cols: 9
                    size_hint_y: None
                    height: self.minimum_height
                    color: 0, 0, 0, 1
                    row_default_height: dp(30)
                    row_force_default: True

