#:import ButtonBehavior kivy.uix.behaviors.ButtonBehavior
<CloseIcon@ButtonBehavior+MDIcon>:
    theme_text_color: "Custom"
    size_hint: None, None
    size: dp(18), dp(18)
    
<TabItem@ButtonBehavior+MDBoxLayout>:
    tab_key: ""
    text: ""
    active: False
    orientation: "horizontal"
    size_hint_y: None
    height: dp(32)
    padding: [dp(12), 0, dp(4), dp(0)]
    spacing: 0
    size_hint_x: None
    width: dp(140)

    canvas.before:
        Color:
            rgba: (0.149, 0.333, 0.729, 1) if root.active else (0.93, 0.93, 0.93, 1)
        RoundedRectangle:
            radius: [10, 10, 0, 0]
            pos: self.pos
            size: self.size
    on_release:
        app.activate_tab_from_widget(root)

    MDLabel:
        text: root.text
        theme_text_color: "Custom"
        text_color: (1, 1, 1, 1) if root.active else (0.149, 0.333, 0.729, 1)
        font_size: "12sp"
        shorten: True
        shorten_from: "right"
        size_hint_x: 1

    CloseIcon:
        icon: "close"
        text_color: (1, 1, 1, 1) if root.active else (0.4, 0.4, 0.4, 1)
        pos_hint: {"center_y": 0.5}
        on_release:
            app.close_tab(root.tab_key)

MDBoxLayout:
    orientation: "vertical"

    ScrollView:
        size_hint_y: None
        height: dp(36)
        do_scroll_y: False
        bar_width: 0

        MDBoxLayout:
            id: tabs_container
            adaptive_width: True
            height: dp(36)
            spacing: dp(4)
            padding: dp(8), 0

    RelativeLayout:
        size_hint_y: None
        height: dp(50)

        MDTopAppBar:
            id: top_bar
            title: app.title
            title_font_size: "28sp"
            left_action_items: [["menu", lambda x: nav_drawer.set_state("open")]]
            right_action_items: [["blank", lambda x: None]]
            md_bg_color: 0.980, 0.729, 0.004, 1
            specific_text_color: 0.149, 0.333, 0.729, 1
            pos_hint: {"top": 1}
            elevation: 0
            padding: [0, -dp(18), 0, 0]

        Label:
            id: time_label
            text: "__-__-__ || --:--:--"
            font_size: "14sp"
            color: 0.149, 0.333, 0.729, 1
            size_hint: None, None
            size: self.texture_size
            pos_hint: {"center_y": 0.5, "right": 0.99}

    MDNavigationLayout:
        x: top_bar.height

        ScreenManager:
            id: screen_manager

            Dashboard:
            DataObat:
            InsertObat:
            EditObat:
            DataGolonganObat:
            InsertGolonganObat:
            EditGolonganObat:

            DataPajak:
            InsertPajak:
            EditPajak:

            DataPelanggan:
            InsertPelanggan:
            EditPelanggan:

            Kasir:
            RiwayatTransaksi:

            SettingsDooka:

        MDNavigationDrawer:
            id: nav_drawer
            radius: (0, 16, 16, 0)

            MDNavigationDrawerMenu:
                MDNavigationDrawerHeader:
                    title: "Menu Utama"
                    text: "Apotek Medika Usada"
                    spacing: "4dp"
                    padding: "12dp", 0, 0, "26dp"

                MDNavigationDrawerItem:
                    icon: "view-dashboard"
                    text: "Dashboard"
                    on_release:
                        app.open_tab("dashboard", "Dashboard", "dashboard")
                        nav_drawer.set_state("close")

                MDNavigationDrawerItem:
                    icon: "pill"
                    text: "Data Obat"
                    on_release:
                        app.open_tab("data_obat", "Data Obat", "data_obat")
                        nav_drawer.set_state("close")

                MDNavigationDrawerItem:
                    icon: "tag"
                    text: "Data Golongan"
                    on_release:
                        app.open_tab("data_golongan_obat", "Data Golongan Obat", "data_golongan_obat")
                        nav_drawer.set_state("close")

                MDNavigationDrawerItem:
                    icon: "currency-usd"
                    text: "Data Pajak"
                    on_release:
                        app.open_tab("data_pajak", "Data Pajak", "data_pajak")
                        nav_drawer.set_state("close")

                MDNavigationDrawerItem:
                    icon: "account-group"
                    text: "Data Pelanggan"
                    on_release:
                        app.open_tab("data_pelanggan", "Data Pelanggan", "data_pelanggan")
                        nav_drawer.set_state("close")

                MDNavigationDrawerItem:
                    icon: "cash-register"
                    text: "Kasir"
                    on_release:
                        kasir_item.height = 0 if kasir_item.height > 0 else dp(48)
                        kasir_item.opacity = 0 if kasir_item.opacity > 0 else 1
                        kasir_item.disabled = not kasir_item.disabled
                        riwayat_item.height = 0 if riwayat_item.height > 0 else dp(48)
                        riwayat_item.opacity = 0 if riwayat_item.opacity > 0 else 1
                        riwayat_item.disabled = not riwayat_item.disabled

                MDNavigationDrawerItem:
                    id: kasir_item
                    icon: "point-of-sale"
                    text: "Buka Kasir"
                    height: 0
                    opacity: 0
                    disabled: True
                    padding: [dp(32), 0, 0, 0]
                    on_release:
                        app.open_tab("Kasir", "Kasir", "Kasir")
                        nav_drawer.set_state("close")
                        kasir_item.height = 0
                        kasir_item.opacity = 0
                        kasir_item.disabled = True
                        riwayat_item.height = 0
                        riwayat_item.opacity = 0
                        riwayat_item.disabled = True
                
                MDNavigationDrawerItem:
                    id: riwayat_item
                    icon: "history"
                    text: "Riwayat Transaksi"
                    height: 0
                    opacity: 0
                    disabled: True
                    padding: [dp(32), 0, 0, 0]
                    on_release:
                        app.open_tab("riwayat_transaksi", "Riwayat_transaksi", "riwayat_transaksi")
                        nav_drawer.set_state("close")
                        kasir_item.height = 0
                        kasir_item.opacity = 0
                        kasir_item.disabled = True
                        riwayat_item.height = 0
                        riwayat_item.opacity = 0
                        riwayat_item.disabled = True

                MDNavigationDrawerItem:
                    icon: "cog"
                    text: "Settings"
                    on_release:
                        app.open_tab("settings_dooka", "Settings_dooka", "settings_dooka")
                        nav_drawer.set_state("close")
#-----------------------------------------------------------------------------------------#

<Dashboard>:
    name: "dashboard"
    MDBoxLayout:
        orientation: "vertical"
        # --- MAIN CONTENT ---
        GridLayout:
            cols: 2
            rows: 2
            spacing: dp(5)
            padding: 0
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0, 0, 0, 0.5
                # Garis vertikal tengah (1dp, full height)
                Rectangle:
                    pos: self.center_x - dp(0.5), self.y
                    size: dp(1), self.height
                # Garis horizontal tengah (1dp, full width)
                Rectangle:
                    pos: self.x, self.center_y - dp(0.5)
                    size: self.width, dp(1)
            AnchorLayout:
                anchor_x: 'center'
                anchor_y: 'center'
                BoxLayout:
                    orientation: 'vertical'
                    size_hint: None, None
                    width: dp(300)
                    height: self.minimum_height
                    spacing: dp(5)
                    Label:
                        text: 'Total Obat = '+ str(root.total_obat)
                        font_size: 30
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0, 0, 0, 1
                    Label:
                        text: 'Total Golongan = '+ str(root.total_golongan)
                        font_size: 30
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0, 0, 0, 1
                    Label:
                        text: 'Total Pajak = '+ str(root.total_pajak)
                        font_size: 30
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0, 0, 0, 1
                    Label:
                        text: 'Total Pelanggan = '+ str(root.total_pelanggan)
                        font_size: 30
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0, 0, 0, 1

            AnchorLayout:
                anchor_x: 'center'
                anchor_y: 'center'
                BoxLayout:
                    orientation: 'vertical'
                    size_hint: 1, 1
                    spacing: dp(6)
                    padding: dp(10)
                    halign: 'center'
                    valign: 'middle'

                    # Judul kartu
                    Label:
                        text: 'Stok Minimum'
                        font_size: dp(20)
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0.149, 0.333, 0.729, 1

                    # Jumlah item low stock (opsional)
                    Label:
                        id: lbl_lowstock_count
                        text: ''   # akan diisi dari Python
                        font_size: dp(14)
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0.2, 0.2, 0.2, 1
                    # List scrollable
                    BoxLayout:
                        padding: dp(4)
                        size_hint_y: 1
                        canvas.before:
                            Color: 
                                rgba: 1, 1, 1, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                            Color: 
                                rgba: 0, 0, 0, 1
                            Line:
                                rounded_rectangle: (self.x + .5, self.y + .5, self.width - 1, self.height - 1, dp(8), dp(8), dp(8), dp(8))
                                width: 1

                        RecycleView:
                            id: rv_lowstock
                            size_hint_y: 1
                            viewclass: "LowStockCard"
                            scroll_type: ["bars", "content"]
                            bar_width: dp(10)
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            RecycleBoxLayout:
                                default_size: None, dp(50)
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: "vertical"
                                spacing: dp(4)

            AnchorLayout:
                anchor_x: 'center'
                anchor_y: 'center'
                BoxLayout:
                    orientation: 'vertical'
                    size_hint: 1, 1
                    spacing: dp(6)
                    padding: dp(10)
                    halign: 'center'
                    valign: 'middle'

                    # Judul kartu
                    Label:
                        text: 'Tanggal Obat Kadaluarsa'
                        font_size: dp(20)
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0.149, 0.333, 0.729, 1

                    # Jumlah item low stock (opsional)
                    Label:
                        id: lbl_kadaluarsa_count
                        text: ''   # akan diisi dari Python
                        font_size: dp(14)
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0.2, 0.2, 0.2, 1
                    # List scrollable
                    BoxLayout:
                        padding: dp(4)
                        size_hint_y: 1
                        canvas.before:
                            Color: 
                                rgba: 1, 1, 1, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                            Color: 
                                rgba: 0, 0, 0, 1
                            Line:
                                rounded_rectangle: (self.x + .5, self.y + .5, self.width - 1, self.height - 1, dp(8), dp(8), dp(8), dp(8))
                                width: 1

                        RecycleView:
                            id: rv_kadaluarsa
                            size_hint_y: 1
                            viewclass: "StokKadaluarsa"
                            scroll_type: ["bars", "content"]
                            bar_width: dp(10)
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            RecycleBoxLayout:
                                default_size: None, dp(50)
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: "vertical"
                                spacing: dp(4)
            AnchorLayout:
                anchor_x: 'center'
                anchor_y: 'center'
                BoxLayout:
                    orientation: 'vertical'
                    size_hint: None, None
                    width: dp(180)
                    height: self.minimum_height
                    spacing: dp(2)
                    Label:
                        text: 'COMING SOON'
                        font_size: 40
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0, 0, 0, 1
                    Label:
                        text: ""
                        font_size: 30
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
                        color: 0, 0, 0, 1

<LowStockCard@BoxLayout>:
    # data yg di-set dari rv.data
    nama_plu: ""
    stok_text: ""
    status_color: 1, 0.6, 0, 1
    orientation: "horizontal"
    size_hint_y: None
    height: dp(50)
    spacing: dp(8)
    padding: 0,0,20,0
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0, 0, 0, 1
        Line:
            rectangle: (self.x + 0.5, self.y + 0.5, self.width - 1, self.height - 1)
            width: 1

    # strip status tipis
    Widget:
        size_hint_x: None
        width: dp(4)
        canvas.before:
            Color:
                rgba: root.status_color
            Rectangle:
                pos: self.x, self.y + dp(8)
                size: self.width, self.height - dp(16)

    # ikon kecil
    MDIcon:
        icon: "pill"
        theme_text_color: "Custom"
        text_color: 0.12, 0.48, 0.93, 1
        size_hint: None, None
        size: dp(20), dp(20)
        pos_hint: {"center_y": .5}

    # nama (1 baris, potong kalau panjang)
    MDLabel:
        text: root.nama_plu
        theme_text_color: "Custom"
        text_color: 0.1, 0.1, 0.1, 1
        bold: True
        shorten: True
        shorten_from: "right"
        halign: "left"
        valign: "middle"
        text_size: self.size

    # badge stok di kanan (kecil, pills)
    MDLabel:
        size_hint_x: None
        width: dp(150)
        text: root.stok_text
        halign: "center"
        valign: "middle"
        theme_text_color: "Custom"
        text_color: 1,1,1 , 1
        canvas.before:
            Color:
                rgba: root.status_color
            RoundedRectangle:
                pos: self.x, self.center_y - dp(12)  # <— center badge vertikal
                size: self.width, dp(24)              # tinggi badge
                radius: [dp(12)]

<StokKadaluarsa@BoxLayout>:
    # data yg di-set dari rv.data
    nama_plu: ""
    tanggal_text: ""
    status_color: 1, 0.6, 0, 1
    orientation: "horizontal"
    size_hint_y: None
    height: dp(50)
    spacing: dp(8)
    padding: 0,0,20,0
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0, 0, 0, 1
        Line:
            rectangle: (self.x + 0.5, self.y + 0.5, self.width - 1, self.height - 1)
            width: 1

    # strip status tipis
    Widget:
        size_hint_x: None
        width: dp(4)
        canvas.before:
            Color:
                rgba: root.status_color
            Rectangle:
                pos: self.x, self.y + dp(8)
                size: self.width, self.height - dp(16)

    # ikon kecil
    MDIcon:
        icon: "pill"
        theme_text_color: "Custom"
        text_color: 0.12, 0.48, 0.93, 1
        size_hint: None, None
        size: dp(20), dp(20)
        pos_hint: {"center_y": .5}

    # nama (1 baris, potong kalau panjang)
    MDLabel:
        text: root.nama_plu
        theme_text_color: "Custom"
        text_color: 0.1, 0.1, 0.1, 1
        bold: True
        shorten: True
        shorten_from: "right"
        halign: "left"
        valign: "middle"
        text_size: self.size

    # badge stok di kanan (kecil, pills)
    MDLabel:
        size_hint_x: None
        width: dp(150)
        text: root.tanggal_text
        halign: "center"
        valign: "middle"
        theme_text_color: "Custom"
        text_color: 1,1,1 , 1
        canvas.before:
            Color:
                rgba: root.status_color
            RoundedRectangle:
                pos: self.x, self.center_y - dp(12)  # <— center badge vertikal
                size: self.width, dp(24)              # tinggi badge
                radius: [dp(12)]

#-----------------------------------------------------------------------------------------#

<MenuItem@ButtonBehavior+BoxLayout>:
    text: ""
    size_hint_y: None
    height: dp(44)
    bg_rgba: 1, 1, 1, 0
    canvas.before:
        Color:
            rgba: root.bg_rgba
        Rectangle:
            pos: self.pos
            size: self.size
    canvas.after:
        Color:
            rgba: 0, 0, 0, 0.5
        Line:
            width: 1
            rectangle: self.x, self.y, self.width, self.height
    MDLabel:
        id: lbl
        text: root.text if hasattr(root, "text") else ""
        theme_text_color: "Custom"
        text_color: 0, 0, 0, 1
        halign: "center"
        valign: "middle"
        text_size: self.size

#-----------------------------------------------------------------------------------------#

<DataObat>:
    name: 'data_obat'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color: 
                rgba: 1, 1, 1, 1
            Rectangle: 
                pos: self.pos
                size: self.size
        RelativeLayout:
            size_hint_y: None
            height: dp(40)
            BoxLayout:
                size_hint: 1, 1
                padding: dp(8)
                spacing: dp(10)
                canvas.before:
                    Color: 
                        rgba: 0.980, 0.729, 0.004, 1
                    Rectangle: 
                        pos: self.pos
                        size: self.size
                NavButton:
                    text: 'Tambah'
                    width: 70
                    bg_normal: 0.149, 0.333, 0.729, 1
                    on_release: app.open_tab("insert_obat", "Insert Obat", "insert_obat")

                NavButton:
                    text: 'Edit'
                    width: 70
                    bg_normal: 0.149, 0.333, 0.729, 1
                    on_release: root.edit_data_obat()

                NavButton:
                    text: 'Hapus'
                    width: 70
                    bg_normal: 0.149, 0.333, 0.729, 1
                    on_release: root.hapus_terpilih()

        BoxLayout:
            id: table_container_obat
            orientation: "vertical"
            size_hint: 1, 1
            ScrollView:
                id: scroll_obat
                do_scroll_x: True
                do_scroll_y: True
                scroll_type: ['bars']
                effect_cls: 'ScrollEffect'
                bar_width: dp(10)
                bar_color: 0.5, 0.5, 0.5, 5
                bar_inactive_color: 0.3, 0.3, 0.3, 1
                bar_pos_x: 'bottom'
                bar_pos_y: 'right'
                GridLayout:
                    id: grid_obat
                    cols: 23  # Jumlah kolom
                    size_hint_y: None
                    height: self.minimum_height
                    color: 0, 0, 0, 1
                    row_default_height: dp(30)
                    row_force_default: True
                    cell_font_size: dp(10)

<InsertObat>:
    name: 'insert_obat'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color: 
                rgba: 1, 1, 1, 1
            Rectangle: 
                pos: self.pos
                size: self.size
        ScrollView:
            bar_width: dp(8)
            do_scroll_x: True
            do_scroll_y: True
            scroll_type: ['bars']
            effect_cls: 'ScrollEffect'
            bar_width: dp(10)
            bar_color: 0.5, 0.5, 0.5, 5
            bar_inactive_color: 0.3, 0.3, 0.3, 1
            bar_pos_x: 'bottom'
            bar_pos_y: 'right'
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(16)
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height
                canvas.before:
                    Color: 
                        rgba: 1, 1, 1, 1
                    Rectangle: 
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    padding: dp(16)
                    spacing: dp(14)
                    height: self.minimum_height
                    canvas.before:
                        Color: 
                            rgba: 0.980, 0.729, 0.004, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(10)]*4

                    GridLayout:
                        cols: 4
                        spacing: dp(10), 0
                        size_hint_y: None
                        height: self.minimum_height
                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel:
                                text: "Golongan"
                            FormInput:
                                id: dropdown_golongan
                                hint_text: "Pilih Golongan"
                                text: root.kode_golongan_aktif
                                readonly: True
                                icon_right: "menu-down"
                                on_focus: 
                                    if self.focus: root.menu_golongan.open()

                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "Pajak"
                            FormInput:
                                id: dropdown_pajak
                                hint_text: "Pilih Pajak"
                                text: root.kode_pajak_aktif
                                readonly: True
                                icon_right: "menu-down"
                                on_focus: 
                                    if self.focus: root.menu_pajak.open()

                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel:
                                text: "Tanggal"
                            FormInput:
                                id: tanggal_kadaluarsa
                                hint_text: "YYYY-MM-DD"
                                icon_right: "calendar"
                                readonly: True
                                on_touch_down:
                                    root.handle_date_touch(self, args[1])

                    GridLayout:
                        cols: 2
                        spacing: dp(10), dp(8)
                        size_hint_y: None
                        height: self.minimum_height
                        GridLayout:
                            cols: 2
