            text:'Apabila Tidak Ada Perubahan Tekan Tombol Simpan'
            font_size: 15
            size_hint_y: None
            height: 30
            halign: 'center'
            valign: 'middle'
            color: 0, 0, 0, 1
            text_size: self.size

        ScrollView:
            id: scroll_edit
            MDBoxLayout:
                id: form_edit_obat
                orientation: "vertical"
                padding: 10
                spacing: 10
