                    on_release: root.menu_golongan.open()

                MDLabel:
                    id: label_kode_golongan_edit
                    text: root.kode_golongan_aktif
                    halign: "center"

                MDTextField:
                    id: rak
                    hint_text: "Rak"

                MDTextField:
                    id: supplier
                    hint_text: "Supplier"

                MDTextField:
                    id: fast_moving
                    hint_text: "Fast Moving (Ya/Tidak)"

                MDTextField:
                    id: kemasan_beli
                    hint_text: "Kemasan Beli"

                MDTextField:
                    id: isi
                    hint_text: "Isi"
                    input_filter: "int"

                MDTextField:
                    id: tanggal_kadaluarsa
                    hint_text: "Tanggal Kadaluarsa (YYYY-MM-DD)"

                MDTextField:
                    id: stok_apotek
                    hint_text: "Stok Apotek"
                    input_filter: "int"

                MDTextField:
                    id: stok_min
                    hint_text: "Stok Minimum"
                    input_filter: "int"

                MDTextField:
                    id: stok_max
                    hint_text: "Stok Maksimum"
                    input_filter: "int"

                MDRaisedButton:
                    id: dropdown_pajak_edit
                    text: "Pilih Pajak"
                    pos_hint: {"center_x": 0.5}
                    on_release: root.menu_pajak.open()

                MDLabel:
                    id: label_kode_pajak_edit
                    text: root.kode_pajak_aktif
                    halign: "center"

                MDRaisedButton:
                    text: "Simpan Data"
                    pos_hint: {"center_x": 0.5}
                    on_release: root.simpan_edit()

