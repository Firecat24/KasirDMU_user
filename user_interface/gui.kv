                    hint_text: "Jenis Pajak"

                MDTextField:
                    id: persen_pajak
                    hint_text: "Persen Pajak"
                    input_filter: "float"

                MDRaisedButton:
                    text: "Simpan Data"
                    pos_hint: {"center_x": 0.5}
                    on_release: root.simpan_data_pajak()

<EditPajak>:
    name: 'edit_pajak'
    BoxLayout:
        orientation: 'vertical'
        Label:
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, 1

            text: 'EDIT DATA PAJAK'
            font_size: 30
            size_hint_y: None
            height: 40
            halign: 'center'
            valign: 'middle'
            color: 0, 0, 0, 1
            text_size: self.size
        
        Label:
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, 1

            text:'Apabila Tidak Ada Perubahan Tekan Tombol Simpan'
            font_size: 15
            size_hint_y: None
            height: 30
            halign: 'center'
            valign: 'middle'
            color: 0, 0, 0, 1
            text_size: self.size

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: 10
                spacing: 10
                size_hint_y: None
                height: self.minimum_height
                pos_hint: {"center_x": 0.5}

                MDTextField:
                    id: jenis_pajak
                    hint_text: "Jenis Pajak"

                MDTextField:
                    id: persen_pajak
                    hint_text: "Persen Pajak"
                    input_filter: "float"

                MDRaisedButton:
                    text: "Simpan Data"
                    pos_hint: {"center_x": 0.5}
                    on_release: root.simpan_edit_pajak()

#-----------------------------------------------------------------------------------------#

<TabelLabel@Label>:
    font_size: '10sp'
    size_hint_y: None
    color: 0, 0, 0, 1
    height: dp(30)
    canvas.before:
        Color:
            rgba: 0.95, 0.95, 0.95, 1  # latar belakang sel
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.85, 0.85, 0.85, 1  # garis border
        Line:
            rectangle: (*self.pos, *self.size)
            width: 1

<TabelCheckBox@BoxLayout>:
    size_hint_y: None
    height: dp(30)
    color: 0, 0, 0, 1
    canvas.before:
        Color:
            rgba: 0.95, 0.95, 0.95, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.85, 0.85, 0.85, 1
        Line:
            rectangle: (*self.pos, *self.size)
            width: 1

    AnchorLayout:
        CheckBox:
            id: checkbox
            size_hint: None, None
            size: dp(20), dp(20)
            color: 0, 0, 0, 1

#-----------------------------------------------------------------------------------------#

<Kasir>:
    name: 'Kasir'
    BoxLayout:
        orientation: 'vertical'
        # Top Header
        BoxLayout:
            size_hint_y: None
            height: 40
            padding: 5
            spacing: 10
            canvas.before:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: 'Dashboard'
                size_hint_x: None
                width: 100
                font_size: 12
                on_release: app.change_screen('dashboard', "right")

            Button:
                text: 'Riwayat Transaksi'
                size_hint_x: None
                width: 150
                font_size: 12
                on_release: app.change_screen('riwayat_transaksi', "left")

            Label:
                id: time_label
                text: '__-__-__ || --:--:--'
                font_size: 14
                halign: 'right'
                valign: 'middle'
                size_hint_x: 1
                color: 0, 0, 0, 1
                text_size: self.size

        Label:
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, 1

            text: 'KASIR'
            font_size: 25
            size_hint_y: None
            height: 30
            halign: 'center'
            valign: 'middle'
            color: 0, 0, 0, 1
            text_size: self.size

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 50
            spacing: 10
            padding: 10

            RelativeLayout:
                size_hint_x: None
                width: 200
                height: 30

                TextInput:
                    id: search_input
                    hint_text: "Cari obat..."
                    multiline: False
                    font_size: 12
                    size_hint: 1, None
                    height: 30
                    padding: [8, 8, 35, 8]
                    foreground_color: 0, 0, 0, 1
                    hint_text_color: 0.5, 0.5, 0.5, 1
                    on_text_validate:
                        app.root.get_screen('Kasir').cari_obat(search_input.text)

                IconButton:
                    source: 'assets/image/3.png'
                    size_hint: None, None
                    size: 20, 20
                    pos: (self.parent.width - 25, 5)
                    on_release:
                        app.root.get_screen('Kasir').cari_obat(search_input.text)

            Spinner:
                id: jenis_pelanggan_spinner
                text: 'Umum'
                values: ['Umum', 'Karyawan', 'BPJS', 'Halodoc', 'Resep', 'Cabang']
                size_hint: None, None
                width: 100
                height: 30
                font_size: 12

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: 30
                size_hint_x: None
                font_size: 12
                width: 100
                spacing: 10
                ToggleButton:
                    id: toggle_kredit
                    text: 'Kredit' if root.is_kredit else 'Tunai'
                    state: 'down' if root.is_kredit else 'normal'
                    on_state:
                        root.toggle_kredit(self.state == 'down')
                        self.text = 'Kredit' if self.state == 'down' else 'Tunai'

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: 30
                size_hint_x: None
                width: 150
                spacing: 10

                TextInput:
                    id: input_tanggal_tempo
                    hint_text: "YYYY-MM-DD"
                    font_size: 12
                    multiline: False
                    disabled: not root.is_kredit
                    input_filter: lambda text, from_undo: ''.join(c for c in text if c in '0123456789-')

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: 30
                spacing: 10
                padding_left: 10

                TextInput:
                    id: input_nama_pelanggan
                    font_size: 12
                    hint_text: "Masukkan nama pelanggan"
                    size_hint_x: None
                    width: 200
                    multiline: False
                    on_text_validate:
                        if self.text.strip(): root.cari_pelanggan(self.text.strip())
                    on_focus: root.periksa_pelanggan_kosong(self)

                Label:
                    id: label_nama_pelanggan
                    text: "Pelanggan Umum"
                    size_hint_x: None
                    width: 250
                    font_size: 12
                    color: 0.2, 0.2, 0.2, 1
                    canvas.before:
                        Color:
                            rgba: 0.95, 0.95, 0.95, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        Color:
                            rgba: 0, 0, 0, 1
                        Line:
                            rectangle: (*self.pos, *self.size)
                            width: 1

                Label:
                    id: label_poin_pelanggan
                    text: "Poin Pelanggan"
                    size_hint_x: None
                    width: 100
                    font_size: 12
                    color: 0.2, 0.2, 0.2, 1
                    canvas.before:
                        Color:
                            rgba: 0.95, 0.95, 0.95, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        Color:
                            rgba: 0, 0, 0, 1
                        Line:
                            rectangle: (*self.pos, *self.size)
                            width: 1

        BoxLayout:
            size_hint_y: None
            height: 40
            spacing: 0
            canvas.before:
                Color:
                    rgba: .9, .9, .9, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0, 0, 0, 1
                Line:
                    rectangle: (*self.pos, *self.size)
                    width: 1

            # Header Nama
            BoxLayout:
                size_hint_x: 0.25
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Nama"
                    color: 0, 0, 0, 1

            # Header Satuan
            BoxLayout:
                size_hint_x: 0.1
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Satuan"
                    color: 0, 0, 0, 1

            # Header Harga
            BoxLayout:
                size_hint_x: 0.15
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Harga"
                    color: 0, 0, 0, 1

            # Header Qty
            BoxLayout:
                size_hint_x: 0.1
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Qty"
                    color: 0, 0, 0, 1

            # Header Diskon
            BoxLayout:
                size_hint_x: 0.1
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Diskon (%)"
                    color: 0, 0, 0, 1

            # Header Total
            BoxLayout:
                size_hint_x: 0.15
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Total"
                    color: 0, 0, 0, 1

            # Header Aksi
            BoxLayout:
                size_hint_x: 0.15
                Label:
                    text: "Aksi"
                    color: 0, 0, 0, 1


        RecycleView:
            id: keranjang_view
            viewclass: 'KeranjangItem'
            scroll_type: ['bars', 'content']
            bar_width: 10

            RecycleBoxLayout:
                default_size: None, 40
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: 5

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: self.minimum_height
            padding: 10
            spacing: 10
            canvas.before:
                Color:
                    rgba: 0.9, 0.9, 0.9, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            BoxLayout:
                spacing: 10
                size_hint_y: None
                size_hint_x: 0.6
                height: 180

                # Diskon Apotek
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.3

                    Label:
                        text: 'Diskon Apotek (Rp)'
                        font_size: 12
                        color: 0, 0, 0, 1
                    TextInput:
                        id: diskon_rp
                        multiline: False
                        input_filter: None
                        disabled: root.ids.diskon_persen.text != ''
                        on_text: 
                            root.update_totals()
                            root.intonly_format("diskon_rp")

                    Label:
                        text: 'Diskon Apotek (%)'
                        font_size: 12
                        color: 0, 0, 0, 1
                    TextInput:
                        id: diskon_persen
                        multiline: False
                        input_filter: 'int'
                        disabled: root.ids.diskon_rp.text != ''
                        on_text: root.update_totals()

                    Label:
                        text: 'Ongkir (Rp)'
                        font_size: 12
                        color: 0, 0, 0, 1
                    TextInput:
                        id: ongkir_input
                        multiline: False
                        input_filter: None
                        on_text:
                            root.update_totals()
                            root.intonly_format("ongkir_input")


                # Cara Bayar (Pop-up trigger)
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.3
                    padding: [20, 0, 0, 20]

                    Label:
                        text: 'Cara Bayar'
                        font_size: 14
                        color: 0, 0, 0, 1

                    Button:
                        id: cara_bayar
                        text: 'Tunai'
                        on_release: root.open_cara_bayar_popup()

                    Label:
                        text: 'Pembayaran (Rp)'
                        font_size: 14
                        color: 0, 0, 0, 1

                    TextInput:
                        id: uang_pelanggan_input
                        multiline: False
                        input_filter: None
                        on_text:
                            root.update_totals()
                            root.intonly_format("uang_pelanggan_input")
                        on_text_validate: root.simpan_transaksi()

                # Ongkir
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.4
                    size_hint_y: None
                    height: 180

                    BoxLayout:
                        padding: [30, 0, 0, 0]
                        Label:
                            id: total_setelah_diskon
                            text: 'Rp0'
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            color: 0, 0, 0, 1
                    BoxLayout:
                        padding: [30, 0, 0, 0]
                        Label:
                            id: total_setelah_ongkir
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            text: 'Rp0'
                            color: 0, 0, 0, 1

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.4
                size_hint_y: None
                height: 180
                BoxLayout:
                    padding: [50, 0, 0, 0]
                    canvas.before:
                        Color:
                            rgba: 0.8, 0.9, 0.9, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        text: "Total Tagihan: Rp{:,.0f}".format(root.total_akhir).replace(',', '.')
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        font_size: 26
                BoxLayout:
                    padding: [50, 0, 0, 0]
                    canvas.before:
                        Color:
                            rgba: 0.8, 0.8, 0.8, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        id: kembalian_label
                        text: 'Kembalian   : Rp{:,.0f}'.format(root.kembalian).replace(',', '.')
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        font_size: 26

<RiwayatTransaksi>:
    name: 'riwayat_transaksi'
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 10

        BoxLayout:
            size_hint_y: None
            height: 40
            spacing: 10

            Button:
                text: '← Kembali ke Kasir'
                on_release: app.root.current = 'Kasir'

            Button:
                text: '🔄 Muat Ulang'
                on_release: root.muat_riwayat_transaksi()

        GridLayout:
            cols: 9
            size_hint_y: None
            height: 30
            spacing: 5

            Label: 
                text: 'Tanggal'
            Label: 
                text: 'No Ref'
            Label: 
                text: 'pelanggan'
            Label: 
                text: 'Kredit'
            Label: 
                text: 'Tempo'
            Label: 
                text: 'Cara Bayar'
            Label: 
                text: 'Harga'
            Label: 
                text: 'Total'
            Label: 
                text: 'Kasir'

        RecycleView:
            id: rv_riwayat
            viewclass: 'RowRiwayat'
            scroll_type: ['bars', 'content']
            bar_width: 10

            RecycleBoxLayout:
                default_size: None, 30
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: 2


<RowRiwayat>:
    cols: 10
    size_hint_y: None
    height: 30
    spacing: 5

    Label: 
        text: root.tanggal
    Label: 
        text: root.no_ref
    Label: 
        text: root.pelanggan
    Label: 
        text: 'Ya' if root.kredit == '1' else 'Tidak'
    Label: 
        text: root.tempo
    Label: 
        text: root.cara_bayar
    Label: 
        text: root.harga
    Label: 
        text: root.total
    Label: 
        text: root.kasir
    Button:
        text: 'Lihat'
        size_hint_x: None
        width: 40
        on_release:
            app.root.get_screen('Kasir').load_transaksi(root.no_ref)
            app.root.current = 'Kasir'
<PopupLayout@BoxLayout>:
    orientation: 'vertical'
    spacing: 10
    padding: 10
    ScrollView:
        BoxLayout:
            id: tombol_layout
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height

<PopupLayoutPelanggan@BoxLayout>:
    orientation: 'vertical'
    spacing: 10
    padding: 10
    ScrollView:
        BoxLayout:
            id: tombol_layout
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height

    Button:
        text: "Ke Halaman Pelanggan"
        size_hint_y: None
        height: 40
        # on_release: app.root.current = 'halaman_pasien'  # atau sesuai nama Screen

<KeranjangItem>:
    spacing: 0
    size_hint_y: None
    height: 40
    orientation: 'horizontal'
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Line:
            rectangle: (*self.pos, *self.size)
            width: 1

    BoxLayout:
        size_hint_x: 0.25
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        Label:
            text: root.nama

    BoxLayout:
        size_hint_x: 0.1
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        Label:
            text: root.satuan

    BoxLayout:
        size_hint_x: 0.15
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        Label:
            text: str("Rp{:,.0f}".format(root.harga).replace(',', '.'))

    BoxLayout:
        size_hint_x: 0.1
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        TextInput:
            text: str(root.qty)
            input_filter: 'int'
            multiline: False
            on_focus: if not self.focus: root.on_qty_changed(self.text); self.text = '1' if self.text.strip() == '' or self.text.strip() == '0' else self.text

    BoxLayout:
        size_hint_x: 0.1
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        TextInput:
            text: str(root.diskon)
            input_filter: 'int'
            multiline: False
            on_focus: if not self.focus: root.on_diskon_changed(self.text); self.text = '0' if self.text.strip() == '' else self.text

    BoxLayout:
        size_hint_x: 0.15
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        Label:
            text: str("Rp{:,.0f}".format(root.total).replace(',', '.'))

    BoxLayout:
        size_hint_x: 0.15
        Button:
            text: "Hapus"
            on_release: app.root.get_screen('Kasir').hapus_item(root.index)

<IconButton@ButtonBehavior+Image>:
    source: ''
    size_hint: None, None
    size: 20, 20