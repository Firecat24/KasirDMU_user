<EditGolonganObat>:
    name: 'edit_golongan_obat'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color: 
                rgba: 1, 1, 1, 1
            Rectangle: 
                pos: self.pos
                size: self.size
        RelativeLayout:
            size_hint_y: None
            height: dp(40)
            BoxLayout:
                size_hint: 1, 1
                padding: dp(8)
                spacing: dp(10)
                canvas.before:
                    Color: 
                        rgba: 0.980, 0.729, 0.004, 1
                    Rectangle: 
                        pos: self.pos
                        size: self.size
                NavButton:
                    text: 'Dashboard'
                    width: 100
                    bg_normal: 0.149, 0.333, 0.729, 1
                    on_release: app.open_tab("dashboard", "Dashboard", "dashboard")

                NavButton:
                    text: 'Data Obat'
                    font_size: 12
                    bg_normal: 0.149, 0.333, 0.729, 1
                    size_hint_x: None
                    width: 100
                    on_release: app.open_tab("data_golongan", "Data Golongan Obat", "data_golongan_obat")
                Widget:
                Label:
                    id: time_label
                    text: '__-__-__ || --:--:--'
                    font_size: 14
                    halign: 'right'
                    valign: 'middle'
                    size_hint_x: 1
                    color: 0.149, 0.333, 0.729, 1
                    text_size: self.size

            Label:
                text: 'EDIT DATA GOLONGAN OBAT'
                font_size: 25
                size_hint_y: None
                height: 40
                bold: True
                halign: 'center'
                valign: 'middle'
                color: 0.149, 0.333, 0.729, 1
                text_size: self.size

        ScrollView:
            bar_width: dp(8)
            do_scroll_x: True
            do_scroll_y: True
            scroll_type: ['bars']
            effect_cls: 'ScrollEffect'
            bar_width: dp(10)
            bar_color: 0.5, 0.5, 0.5, 5
            bar_inactive_color: 0.3, 0.3, 0.3, 1
