WindowsManager:
    canvas.before:
        Color:
            rgba: 0.7, 0.7, 0.7, 1
        Rectangle:
            pos: self.pos
            size: self.size

    Dashboard:

    DataObat:
    InsertObat:
    EditObat:

    DataGolonganObat:
    InsertGolonganObat:
    EditGolonganObat:

    DataPajak:
    InsertPajak:
    EditPajak:

    Kasir:

#-------------------------------------------------------------------------------------------------------------------#

<Dashboard>:
    name: 'dashboard'
    BoxLayout:
        orientation: 'vertical'

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 40
            padding: 5
            spacing: 10
            canvas.before:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Spinner:
                id: menu_spinner
                text: 'Menu'
                values: ['Obat', 'Pajak', 'Golongan']
                size_hint_x: None
                width: 100
                font_size: 12
                on_text:
                    if self.text == 'Obat': app.change_screen('data_obat')
                    elif self.text == 'Golongan': app.change_screen('data_golongan_obat')
                    elif self.text == 'Pajak': app.change_screen('data_pajak')
                    self.text = 'Menu'

            Button:
                id: kasir
                text: 'Kasir'
                size_hint_x: None
                width: 100
                font_size: 12
                on_release: app.change_screen('Kasir')

            Label:
                id: time_label
                text: '--:--:--'
                font_size: 14
                halign: 'right'
                valign: 'middle'
                size_hint_x: 1
                color: 0, 0, 0, 1
                text_size: self.size
        
        Label:
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, 1

            text: 'DASHBOARD'
            font_size: 30
            size_hint_y: None
            height: 40
            halign: 'center'
            valign: 'middle'
            color: 0, 0, 0, 1
            text_size: self.size

        # Main content
        GridLayout:
            size: root.width, root.height
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            cols: 2
            rows: 2
            padding: 10
            spacing: 10

            Button:
                text: 'Insert PPN'
                size_hint: None, None
                size: 200, 100
                on_release: app.change_screen('insert_PPN')

            Button:
                text: 'Insert Golongan Obat'
                size_hint: None, None
                size: 200, 100
                on_release: app.change_screen('insert_golongan_obat')

            Button:
                text: 'Insert PPN'
                size_hint: None, None
                size: 200, 100
                on_release: app.change_screen('insert_PPN')

            Button:
                text: 'Insert Golongan Obat'
                size_hint: None, None
                size: 200, 100
                on_release: app.change_screen('insert_golongan_obat')


#-------------------------------------------------------------------------------------------------------------------#

<DataObat>:
    name: 'data_obat'
    BoxLayout:
        orientation: 'vertical'
        
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 40
            padding: 5
            spacing: 10
            canvas.before:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: 'Kembali'
                font_size: 12
                size_hint_x: None
                width: 100
                on_release: app.change_screen('dashboard',"right")
            Button:
                text: 'Add Obat'
                font_size: 12
                size_hint_x: None
                width: 100
                on_release: app.change_screen('insert_obat',"left")
            Button:
                text: 'Edit Obat'
                font_size: 12
                size_hint_x: None
                width: 100
                on_release: root.edit_data_obat()
            Button:
                text: "Hapus Obat"
                font_size: 12
                size_hint_x: None
                width: 100
                on_release: root.hapus_terpilih()

        Label:
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, 1

            text: 'DATA OBAT'
            font_size: 30
            size_hint_y: None
            height: 40
            halign: 'center'
            valign: 'middle'
            color: 0, 0, 0, 1
            text_size: self.size

        BoxLayout:
            id: table_container_obat
            orientation: 'vertical'
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

<InsertObat>:
    name: 'insert_obat'
    BoxLayout:
        orientation: 'vertical'
        
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 40
            padding: 5
            spacing: 10
            canvas.before:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: 'Kembali'
                font_size: 12
                size_hint_x: None
                width: 100
                on_release: app.change_screen('dashboard',"right")
            Button:
                text: 'Data Obat'
                font_size: 12
                size_hint_x: None
                width: 100
                on_release: app.change_screen('data_obat',"right")

        Label:
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.7, 0.7, 0.7, 1
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, 1

            text: 'ISI DATA OBAT'
            font_size: 30
            size_hint_y: None
            height: 40
            halign: 'center'
            valign: 'middle'
            color: 0, 0, 0, 1
            text_size: self.size

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: 10
                spacing: 10
                size_hint_y: None
                height: self.minimum_height
                pos_hint: {"center_x": 0.5}

                MDTextField:
                    hint_text: "ID"
                    helper_text: "Biarkan kosong untuk auto increment"
                    helper_text_mode: "on_focus"
                    readonly: True

                MDTextField:
                    id: jenis
                    hint_text: "Jenis"

                MDTextField:
                    id: plu
                    hint_text: "PLU"

                MDTextField:
                    id: nama_produk
                    hint_text: "Nama Produk"

                MDTextField:
                    id: satuan
                    hint_text: "Satuan"

                MDTextField:
                    id: harga_beli
                    hint_text: "Harga Beli"
                    input_filter: "float"

                MDRaisedButton:
                    id: dropdown_golongan
                    text: "Pilih Golongan"
                    pos_hint: {"center_x": 0.5}
                    on_release: root.menu_golongan.open()

                MDLabel:
                    id: label_kode_golongan
                    text: root.kode_golongan_aktif
                    halign: "center"

                MDTextField:
                    id: rak
                    hint_text: "Rak"

                MDTextField:
                    id: supplier
                    hint_text: "Supplier"

                MDTextField:
                    id: fast_moving
                    hint_text: "Fast Moving (Ya/Tidak)"

                MDTextField:
                    id: kemasan_beli
                    hint_text: "Kemasan Beli"

                MDTextField:
                    id: isi
                    hint_text: "Isi"
                    input_filter: "int"

                MDTextField:
                    id: tanggal_kadaluarsa
                    hint_text: "Tanggal Kadaluarsa (YYYY-MM-DD)"

                MDTextField:
                    id: stok_apotek
                    hint_text: "Stok Apotek"
                    input_filter: "int"

                MDTextField:
                    id: stok_min
                    hint_text: "Stok Minimum"
                    input_filter: "int"

                MDTextField:
                    id: stok_max
                    hint_text: "Stok Maksimum"
                    input_filter: "int"

                MDRaisedButton:
                    id: dropdown_pajak
                    text: "Pilih Pajak"
                    on_release: root.menu_pajak.open()

                MDLabel:
                    id: label_kode_pajak
                    text: root.kode_pajak_aktif
                    halign: "center"

                MDRaisedButton:
                    text: "Simpan Data"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.simpan_data_obat()

<EditObat>
    name: 'edit_obat'
    BoxLayout:
        orientation: 'vertical'
    
