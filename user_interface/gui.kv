<DataGolonganObat>:
    name: 'data_golongan_obat'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color: 
                rgba: 1, 1, 1, 1
            Rectangle: 
                pos: self.pos
                size: self.size
        RelativeLayout:
            size_hint_y: None
            height: dp(40)
            BoxLayout:
                size_hint: 1, 1
                padding: dp(8)
                spacing: dp(10)
                canvas.before:
                    Color: 
                        rgba: 0.980, 0.729, 0.004, 1
                    Rectangle: 
                        pos: self.pos
                        size: self.size
                NavButton:
                    text: 'Tambah'
                    width: 70
                    bg_normal: 0.149, 0.333, 0.729, 1
                    on_release: app.open_tab("insert_golongan_obat", "Insert Golongan Obat", "insert_golongan_obat")

                NavButton:
                    text: 'Edit'
                    width: 70
                    bg_normal: 0.149, 0.333, 0.729, 1
                    on_release: root.edit_data_golongan_obat()

                NavButton:
                    text: 'Hapus'
                    width: 70
                    bg_normal: 0.149, 0.333, 0.729, 1
                    on_release: root.hapus_terpilih()

        BoxLayout:
            id: table_container_golongan
            orientation: "vertical"
            size_hint: 1, 1
            ScrollView:
                id: scroll_golongan
                do_scroll_x: True
                do_scroll_y: True
                scroll_type: ['bars']
                effect_cls: 'ScrollEffect'
                bar_width: dp(10)
                bar_color: 0.5, 0.5, 0.5, 5
                bar_inactive_color: 0.3, 0.3, 0.3, 1
                bar_pos_x: 'bottom'
                bar_pos_y: 'right'
                GridLayout:
                    id: grid_golongan
                    cols: 9
                    size_hint_y: None
                    height: self.minimum_height
                    color: 0, 0, 0, 1
                    row_default_height: dp(30)
                    row_force_default: True
                    cell_font_size: dp(15)

<InsertGolonganObat>:
    name: 'insert_golongan_obat'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color: 
                rgba: 1, 1, 1, 1
            Rectangle: 
                pos: self.pos
                size: self.size
        ScrollView:
            bar_width: dp(8)
            do_scroll_x: True
            do_scroll_y: True
            scroll_type: ['bars']
            effect_cls: 'ScrollEffect'
            bar_width: dp(10)
            bar_color: 0.5, 0.5, 0.5, 5
            bar_inactive_color: 0.3, 0.3, 0.3, 1
            bar_pos_x: 'bottom'
            bar_pos_y: 'right'
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(16)
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height
                canvas.before:
                    Color: 
                        rgba: 1, 1, 1, 1
                    Rectangle: 
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    padding: dp(16)
                    spacing: dp(14)
                    height: self.minimum_height
                    canvas.before:
                        Color: 
                            rgba: 0.980, 0.729, 0.004, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(10)]*4
                    GridLayout:
                        cols: 2
                        spacing: dp(10), dp(8)
                        size_hint_y: None
                        height: self.minimum_height
                        GridLayout:
