                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "ID"
                            FormInput:
                                hint_text: "ID (Biarkan Kosong)"
                                disabled: True

                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "Nama Pelanggan"
                            FormInput:
                                id: nama_pelanggan
                                hint_text: "Nama Pelanggan"

                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "Nomer Telfon"
                            FormInput:
                                id: nomor_telfon
                                hint_text: "Nomer Telfon"

                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "Alamat"
                            FormInput:
                                id: alamat
                                hint_text: "Alamat"

                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "Poin Pelanggan"
                            FormInput:
                                id: poin
                                hint_text: "Poin Pelanggan"
                                disabled: True

                    PrimaryButton:
                        text: "Simpan Data"
                        size_hint_x: 1
                        on_release: root.simpan_data_pelanggan()

<EditPelanggan>:
    name: 'edit_pelanggan'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color: 
                rgba: 1, 1, 1, 1
            Rectangle: 
                pos: self.pos
                size: self.size
        ScrollView:
            bar_width: dp(8)
            do_scroll_x: True
            do_scroll_y: True
            scroll_type: ['bars']
            effect_cls: 'ScrollEffect'
            bar_width: dp(10)
            bar_color: 0.5, 0.5, 0.5, 5
            bar_inactive_color: 0.3, 0.3, 0.3, 1
            bar_pos_x: 'bottom'
            bar_pos_y: 'right'
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(16)
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height
                canvas.before:
                    Color: 
                        rgba: 1, 1, 1, 1
                    Rectangle: 
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    padding: dp(16)
                    spacing: dp(14)
                    height: self.minimum_height
                    canvas.before:
                        Color: 
                            rgba: 0.980, 0.729, 0.004, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(10)]*4
                    GridLayout:
                        cols: 2
                        spacing: dp(10), dp(8)
                        size_hint_y: None
                        height: self.minimum_height
                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "ID"
                            FormInput:
                                id: id
                                hint_text: "ID"
                                disabled: True
                                
                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "Nama Pelanggan"
                            FormInput:
                                id: nama_pelanggan
                                hint_text: "Nama Pelanggan"

                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "Nomor Telfon"
                            FormInput:
                                id: nomor_telfon
                                hint_text: "Nomor Telfon"

                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "Alamat"
                            FormInput:
                                id: alamat
                                hint_text: "Alamat"

                        GridLayout:
                            cols: 2
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 1, 1, 1, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel: 
                                text: "Poin Pelanggan"
                            FormInput:
                                id: poin
                                hint_text: "Poin Pelanggan"
                                disabled: True

                    PrimaryButton:
                        text: "Simpan Data"
                        size_hint_x: 1
                        on_release: 
                            root.simpan_edit_pelanggan()

#-----------------------------------------------------------------------------------------#

<TabelHeader@Label>:
    size_hint_y: None
    height: dp(30)
    bold: True
    text_size: self.size
    halign: 'center'
    valign: 'middle'
    color: 0, 0, 0, 1
    canvas.before:
        Color: 
            rgba: 0.98, 0.73, 0.00, 1
        Rectangle: 
            pos: self.pos
            size: self.size
        Color: 
            rgba: 0, 0, 0, 1
        Line: 
            rectangle: (*self.pos, *self.size)
            width: 1

<TabelCell@Label>:
    size_hint_y: None
    height: dp(30)
    font_size: getattr(self.parent, 'cell_font_size', dp(10))
    text_size: self.size
    halign: 'center'
    valign: 'middle'
    color: 0, 0, 0, 1
    canvas.before:
        Color: 
            rgba: 1, 1, 1, 1
        Rectangle: 
            pos: self.pos
            size: self.size
        Color: 
            rgba: 0, 0, 0, 1
        Line: 
            rectangle: (*self.pos, *self.size)
            width: 1

<TabelCheckBox@BoxLayout>:
    size_hint_y: None
    height: dp(30)
    color: 0, 0, 0, 1
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0, 0, 0, 1
        Line:
            rectangle: (*self.pos, *self.size)
            width: 1

    AnchorLayout:
        CheckBox:
            id: checkbox
            size_hint: None, None
            size: dp(20), dp(20)
            color: 0, 0, 0, 1

#-----------------------------------------------------------------------------------------#

<Kasir>:
    name: 'Kasir'
    BoxLayout:
        orientation: 'vertical'
        # Top Header
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 50
            spacing: 10
            padding: 10

            RelativeLayout:
                size_hint_x: None
                width: 200
                height: 30

                TextInput:
                    id: search_input
                    hint_text: "Cari obat..."
                    multiline: False
                    font_size: 12
                    size_hint: 1, None
                    height: 30
                    padding: [8, 8, 35, 8]
                    foreground_color: 0, 0, 0, 1
                    hint_text_color: 0.5, 0.5, 0.5, 1
                    on_text_validate:
                        app.root.ids.screen_manager.get_screen('Kasir').cari_obat(search_input.text)

                IconButton:
                    source: 'assets/image/3.png'
                    size_hint: None, None
                    size: 20, 20
                    pos: (self.parent.width - 25, 5)
                    on_release:
                        app.root.ids.screen_manager.get_screen('Kasir').cari_obat(search_input.text)

            Spinner:
                id: jenis_pelanggan_spinner
                text: 'Umum'
                values: ['Umum', 'Karyawan', 'BPJS', 'Halodoc', 'Resep', 'Cabang']
                size_hint: None, None
                width: 100
                height: 30
                font_size: 12
                on_text: root.set_jenis_pelanggan(self.text)

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: 30
                size_hint_x: None
                font_size: 12
                width: 100
                spacing: 10
                ToggleButton:
                    id: toggle_kredit
                    text: 'Kredit' if root.is_kredit else 'Tunai'
                    state: 'down' if root.is_kredit else 'normal'
                    on_state:
                        root.toggle_kredit(self.state == 'down')
                        self.text = 'Kredit' if self.state == 'down' else 'Tunai'

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: 30
                size_hint_x: None
                width: 150
                spacing: 10

                TextInput:
                    id: input_tanggal_tempo
                    hint_text: "YYYY-MM-DD"
                    font_size: 12
                    multiline: False
                    disabled: not root.is_kredit
                    input_filter: lambda text, from_undo: ''.join(c for c in text if c in '0123456789-')

            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: 30
                spacing: 10
                padding_left: 10

                TextInput:
                    id: input_nama_pelanggan
                    font_size: 12
                    hint_text: "Masukkan nama pelanggan"
                    size_hint_x: None
                    width: 200
                    multiline: False
                    on_text_validate:
                        if self.text.strip(): root.cari_pelanggan(self.text.strip())
                    on_focus: root.periksa_pelanggan_kosong(self)

                Label:
                    text: "Pasien: "
                    size_hint_x: None
                    width: 50
                    font_size: 12
                    color: 0.2, 0.2, 0.2, 1
                            
                Label:
                    id: label_nama_pelanggan
                    text: "Pelanggan Umum"
                    size_hint_x: None
                    width: 150
                    font_size: 12
                    color: 0.2, 0.2, 0.2, 1
                    canvas.before:
                        Color:
                            rgba: 0.95, 0.95, 0.95, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        Color:
                            rgba: 0, 0, 0, 1
                        Line:
                            rectangle: (*self.pos, *self.size)
                            width: 1

                Label:
                    id: label_poin_pelanggan
                    text: "Poin Pelanggan"
                    size_hint_x: None
                    width: 100
                    font_size: 12
                    color: 0.2, 0.2, 0.2, 1
                    canvas.before:
                        Color:
                            rgba: 0.95, 0.95, 0.95, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        Color:
                            rgba: 0, 0, 0, 1
                        Line:
                            rectangle: (*self.pos, *self.size)
                            width: 1

                Label:
                    id: label_penjaga_kasir
                    text: "Kasir: " + root.penjaga_kasir
                    size_hint_x: None
                    width: 100
                    font_size: 12
                    color: 0.2, 0.2, 0.2, 1
                    canvas.before:
                        Color:
                            rgba: 0.95, 0.95, 0.95, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        Color:
                            rgba: 0, 0, 0, 1
                        Line:
                            rectangle: (*self.pos, *self.size)
                            width: 1
            
                MDRaisedButton:
                    text: "Pending"
                    on_release: root.pending_transaksi()
                    
                    # Warna
                    md_bg_color: 0.149, 0.333, 0.729, 1
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    
                    # 1. Hilangkan Bayangan (Kunci untuk versi lama)
                    elevation: 0
                    
                    # 2. Atur Ukuran Ramping
                    size_hint: None, None
                    height: dp(30)  # Paksa tinggi sama dengan input box
                    width: dp(80)
                    
                    # Posisi Tengah
                    pos_hint: {'center_y': 0.5}

                # --- TOMBOL RELOAD ---
                MDRaisedButton:
                    text: "Reload"
                    on_release: root.reload_pending()
                    
                    # Warna
                    md_bg_color: 0.149, 0.333, 0.729, 1
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    
                    # 1. Hilangkan Bayangan
                    elevation: 0
                    
                    # 2. Atur Ukuran Ramping
                    size_hint: None, None
                    height: dp(30)
                    width: dp(80)
                    
                    # Posisi Tengah
                    pos_hint: {'center_y': 0.5}

        BoxLayout:
            size_hint_y: None
            height: 40
            spacing: 0
            canvas.before:
                Color:
                    rgba: 0.980, 0.729, 0.004, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0, 0, 0, 1
                Line:
                    rectangle: (*self.pos, *self.size)
                    width: 1

            # Header Nama
            BoxLayout:
                size_hint_x: 0.25
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Nama"
                    color: 0.149, 0.333, 0.729, 1

            # Header Satuan
            BoxLayout:
                size_hint_x: 0.1
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Satuan"
                    color: 0.149, 0.333, 0.729, 1

            # Header Harga
            BoxLayout:
                size_hint_x: 0.15
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Harga"
                    color: 0.149, 0.333, 0.729, 1

            # Header Qty
            BoxLayout:
                size_hint_x: 0.1
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Qty"
                    color: 0.149, 0.333, 0.729, 1

            # Header Diskon
            BoxLayout:
                size_hint_x: 0.1
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Diskon (%)"
                    color: 0.149, 0.333, 0.729, 1

            # Header Total
            BoxLayout:
                size_hint_x: 0.15
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        points: [self.right, self.y, self.right, self.top]
                        width: 1
                Label:
                    text: "Total"
                    color: 0.149, 0.333, 0.729, 1

            # Header Aksi
            BoxLayout:
                size_hint_x: 0.15
                Label:
                    text: "Aksi"
                    color: 0.149, 0.333, 0.729, 1


        RecycleView:
            id: keranjang_view
            viewclass: 'KeranjangItem'
            scroll_type: ['bars', 'content']
            bar_width: 10

            RecycleBoxLayout:
                default_size: None, 40
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: 5

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: self.minimum_height
            canvas.before:
                Color:
                    rgba: 0.980, 0.729, 0.004, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            BoxLayout:
                spacing: 10
                padding: 10
                size_hint_y: None
                size_hint_x: 0.6
                height: 180

                # Diskon Apotek
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.3

                    Label:
                        text: 'Diskon Apotek (Rp)'
                        font_size: 12
                        color: 0.149, 0.333, 0.729, 1
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: 30
                        spacing: 5

                        TextInput:
                            id: diskon_rp
                            font_size: 12
                            multiline: False
                            input_filter: None
                            on_focus:
                                if self.focus: root.last_diskon_input = 'rp'
                            on_text:
                                root.update_totals()
                                app.formatter.intonly_format(self)

                        CheckBox:
                            id: diskon_rp_checkbox
                            size_hint_x: None
                            width: 30
                            on_active: root.on_diskon_rp_checkbox(self.active)

                            canvas.before:
                                Color:
                                    rgba: (0, 0.5, 0.2, 1) if self.active else (0.341, 0.682, 0.686, 1)
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            canvas.after:
                                Color:
                                    rgba: (1, 1, 1, 1) if self.active else (1, 1, 1, 1)
                                Line:
                                    width: 2
                                    rectangle: (*self.pos, *self.size)

                    Label:
                        text: 'Diskon Apotek (%)'
                        font_size: 12
                        color: 0.149, 0.333, 0.729, 1
                    TextInput:
                        id: diskon_persen
                        font_size: 12
                        multiline: False
                        input_filter: 'int'
                        on_focus:
                            if self.focus: root.last_diskon_input = 'persen'
                        on_text:
                            root.update_totals()

                    Label:
                        text: 'Ongkir (Rp)'
                        font_size: 12
                        color: 0.149, 0.333, 0.729, 1
                    TextInput:
                        id: ongkir_input
                        multiline: False
                        input_filter: None
                        on_text:
                            root.update_totals()
                            app.formatter.intonly_format(self)


                # Cara Bayar (Pop-up trigger)
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.3
                    padding: [20, 0, 0, 20]

                    Label:
                        text: 'Cara Bayar'
                        font_size: 14
                        color: 0.149, 0.333, 0.729, 1

                    BoxLayout:
                        id: cara_bayar
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: 40
                        font_size: 12
                        spacing: 10
                        ToggleButton:
                            id: toggle_non_tunai
                            text: 'Non Tunai' if root.is_non_tunai else 'Tunai'
                            state: 'down' if root.is_non_tunai else 'normal'
                            on_state:
                                root.toggle_non_tunai(self.state == 'down')
                                self.text = 'Non Tunai' if self.state == 'down' else 'Tunai'

                    Label:
                        text: 'Pembayaran (Rp)'
                        font_size: 14
                        color: 0.149, 0.333, 0.729, 1

                    TextInput:
                        id: uang_pelanggan_input
                        multiline: False
                        input_filter: None
                        on_text:
                            root.update_totals()
                            app.formatter.intonly_format(self)
                        on_text_validate: root.simpan_transaksi()

                # Ongkir
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_x: 0.4
                    size_hint_y: None
                    height: 180

                    BoxLayout:
                        padding: [30, 0, 0, 0]
                        Label:
                            id: total_setelah_diskon
                            text: 'Rp0'
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            color: 0.149, 0.333, 0.729, 1
                    BoxLayout:
                        padding: [30, 0, 0, 0]
                        Label:
                            id: total_setelah_ongkir
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            text: 'Rp0'
                            color: 0.149, 0.333, 0.729, 1

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.4
                size_hint_y: None
                height: 180
                BoxLayout:
                    padding: [50, 0, 0, 0]
                    canvas.before:
                        Color:
                            rgba: 0, 0, 0, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        text: "Total Tagihan: Rp{:,.0f}".format(root.total_akhir).replace(',', '.')
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                        color: 1, 1, 1, 1
                        font_size: 26
                BoxLayout:
                    padding: [50, 0, 0, 0]
                    canvas.before:
                        Color:
                            rgba: 0, 1, 0, 1
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        id: kembalian_label
                        text: 'Kembalian   : Rp{:,.0f}'.format(root.kembalian).replace(',', '.')
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        font_size: 26

<RiwayatTransaksi>:
    name: 'riwayat_transaksi'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color: 
                rgba: 1, 1, 1, 1
            Rectangle: 
                pos: self.pos
                size: self.size
        BoxLayout:
            id: table_container_riwayat_transaksi
            orientation: "vertical"
            size_hint: 1, 1
            ScrollView:
                id: scroll_riwayat_transaksi
                do_scroll_x: True
                do_scroll_y: True
                scroll_type: ['bars']
                effect_cls: 'ScrollEffect'
                bar_width: dp(10)
                bar_color: 0.5, 0.5, 0.5, 1
                bar_inactive_color: 0.3, 0.3, 0.3, 1
                bar_pos_x: 'bottom'
                bar_pos_y: 'right'

                GridLayout:
                    id: grid_riwayat_transaksi
                    cols: 12
                    size_hint_x: None
                    size_hint_y: None
                    width: self.minimum_width
                    height: self.minimum_height
                    row_force_default: True
                    row_default_height: dp(30)
                    cell_font_size: dp(15)

<THead@Label>:
    size_hint_y: None
    height: dp(30)
    bold: True
    color: 0,0,0,1
    text_size: self.size
    halign: 'center'
    valign: 'middle'
    canvas.before:
        Color: 
            rgba: 0.98, 0.73, 0.0, 1
        Rectangle: 
            pos: self.pos
            size: self.size
        Color: 
            rgba: 0,0,0,1
        Line: 
            rectangle: (*self.pos, *self.size)
            width: 1

<TCell@Label>:
    size_hint_y: None
    height: dp(30)
    color: 0,0,0,1
    font_size: getattr(self.parent, 'cell_font_size', dp(14))
    text_size: self.size
    halign: 'center'
    valign: 'middle'
    canvas.before:
        Color:
            rgba: 1,1,1,1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0,0,0,1
        Line: 
            rectangle: (*self.pos, *self.size)
            width: 1

<TCellButton@Button>:
    size_hint_y: None
    height: dp(30)
    background_normal: ''
    background_down: ''
    background_disabled_normal: ''
    background_disabled_down: ''
    background_color: 0.149, 0.333, 0.729, 1
    color: 1, 1, 1, 1

    # Gambar sendiri
    canvas.before:
        Color:
            rgba: (0.7, 0.7, 0.7, 1) if self.disabled else self.background_color
        Rectangle:
            pos: self.pos
            size: self.size
    canvas.after:
        Color: 
            rgba: 0, 0, 0, 1
        Line:
            rectangle: (*self.pos, *self.size)
            width: 1

<PopupLayout@BoxLayout>:
    orientation: 'vertical'
    spacing: 10
    padding: 10
    ScrollView:
        BoxLayout:
            id: tombol_layout
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height

<PopupLayoutPelanggan@BoxLayout>:
    orientation: 'vertical'
    spacing: 10
    padding: 10
    ScrollView:
        BoxLayout:
            id: tombol_layout
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height

    Button:
        text: "Ke Halaman Pelanggan"
        size_hint_y: None
        height: 40
        on_release: app.root.current = 'data_pelanggan'

<KeranjangItem>:
    spacing: 0
    size_hint_y: None
    height: 40
    orientation: 'horizontal'
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Line:
            rectangle: (*self.pos, *self.size)
            width: 1

    BoxLayout:
        size_hint_x: 0.25
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        Label:
            text: root.nama
            color: 0, 0, 0, 1

    BoxLayout:
        size_hint_x: 0.1
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        Label:
            text: root.satuan
            color: 0, 0, 0, 1

    BoxLayout:
        size_hint_x: 0.15
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        Label:
            text: str("Rp{:,.0f}".format(root.harga).replace(',', '.'))
            color: 0, 0, 0, 1

    BoxLayout:
        size_hint_x: 0.1
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        TextInput:
            text: str(root.qty)
            input_filter: 'int'
            multiline: False
            on_focus: if not self.focus: root.on_qty_changed(self.text); self.text = '1' if self.text.strip() == '' or self.text.strip() == '0' else self.text

    BoxLayout:
        size_hint_x: 0.1
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        TextInput:
            text: str(root.diskon)
            input_filter: 'int'
            multiline: False
            on_focus: if not self.focus: root.on_diskon_changed(self.text); self.text = '0' if self.text.strip() == '' else self.text

    BoxLayout:
        size_hint_x: 0.15
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1
        Label:
            text: str("Rp{:,.0f}".format(root.total).replace(',', '.'))
            color: 0, 0, 0, 1

    BoxLayout:
        size_hint_x: 0.15
        padding: 0
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Line:
                points: [self.right, self.y, self.right, self.top]
                width: 1

        Button:
            text: "Hapus"
            size_hint: 1, 1
            background_normal: ''
            background_down: ''
            background_color: 0.35, 0.35, 0.35, 1
            border: 0, 0, 0, 0
            padding: 0, 0
            on_release: app.root.ids.screen_manager.get_screen('Kasir').hapus_item(root.index)

<IconButton@ButtonBehavior+Image>:
    source: ''
    size_hint: None, None
    size: 20, 20

<NavButton@Button>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    font_size: 12
    size_hint_x: None
    size_hint_y: None
    height: 24
    width: 150
    halign: 'left'
    valign: 'middle'
    padding: dp(10), dp(8)
    bg_normal: 0.12, 0.48, 0.93, 1
    bg_down:   0.09, 0.38, 0.75, 1

    canvas.before:
        Color:
            rgba: self.bg_down if self.state == 'down' else self.bg_normal
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(5), dp(5), dp(5), dp(5)]

#-----------------------------------------------------------------------------------------#
# ==== Komponen bersama (sekali definisi) ====
<FormLabel@Label>:
    font_size: dp(16)
    color: 0.149, 0.333, 0.729, 1
    text_size: self.size
    halign: 'center'
    valign: 'middle'

<FormInput@TextInput>:
    size_hint_y: None
    height: dp(36)
    padding: dp(10), dp(8)
    multiline: False
    write_tab: False  # tab pindah field, bukan insert tab

<PrimaryButton@Button>:
    size_hint: None, None
    height: dp(36)
    width: dp(120)
    font_size: dp(14)
    color: 1, 1, 1, 1
    background_normal: ''
    background_down: ''
    background_color: 0.149, 0.333, 0.729, 1
    border: 0, 0, 0, 0
    canvas.before:
        Color: 
            rgba: self.background_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6), dp(6), dp(6), dp(6)]


<SettingsDooka>:
    name: 'settings_dooka'
    BoxLayout:
        orientation: 'vertical'
        AnchorLayout:
            anchor_y: 'top'
            padding: dp(16)

            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                BoxLayout:
                    size_hint_y: None
                    height: self.minimum_height
                    padding: dp(16)
                    canvas.before:
                        Color: 
                            rgba: 1, 1, 1, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8)]*4
                        Color: 
                            rgba: 0, 0, 0, .10
                        Line:
                            rectangle: (*self.pos, *self.size)
                            width: 1
                    GridLayout:
                        cols: 2
                        rows: 2
                        spacing: dp(5), dp(5)
                        size_hint_y: None
                        height: self.minimum_height

                        # Kolom kiri
                        GridLayout:
                            cols: 3
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 0.980, 0.729, 0.004, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel:
                                text: 'Pembulatan Harga'
                                size_hint_y: None
                                height: dp(36)
                            FormInput:
                                id: pembulatan_input
                                size_hint_y: None
                                height: dp(36)
                                text: str(root.pembulatan)
                                input_filter: 'int'
                                on_text_validate: root.ubah_pembulatan(int(self.text))
                            PrimaryButton:
                                text: 'Simpan'
                                size_hint_y: None
                                height: dp(36)
                                on_release: root.ubah_pembulatan(int(pembulatan_input.text))

                        # Kolom kanan
                        GridLayout:
                            cols: 3
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 0.980, 0.729, 0.004, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel:
                                text: 'POIN'
                                size_hint_y: None
                                height: dp(36)
                            FormInput:
                                id: pembagian_perpoin
                                size_hint_y: None
                                height: dp(36)
                                text: str(root.pembagian_perpoin)
                                input_filter: 'int'
                                on_text_validate: root.ubah_pembagian_perpoin(int(self.text))
                            PrimaryButton:
                                text: 'Simpan'
                                size_hint_y: None
                                height: dp(36)
                                on_release: root.ubah_pembagian_perpoin(int(pembagian_perpoin.text))

                        # Kolom kiri
                        GridLayout:
                            cols: 3
                            spacing: dp(8), 0
                            padding: dp(10), dp(8), dp(10), dp(8)
                            size_hint_y: None
                            height: self.minimum_height
                            row_force_default: False
                            canvas.before:
                                Color:
                                    rgba: 0.980, 0.729, 0.004, 1
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(8)]*4
                            FormLabel:
                                text: 'Penjaga Kasir'
                                size_hint_y: None
                                height: dp(36)
                            FormInput:
                                id: penjaga_kasir
                                size_hint_y: None
                                height: dp(36)
                                text: str(root.penjaga_kasir)
                                on_text_validate: root.ubah_penjaga_kasir(self.text)

                            PrimaryButton:
                                text: 'Simpan'
                                size_hint_y: None
                                height: dp(36)
                                on_release: root.ubah_penjaga_kasir(penjaga_kasir.text)