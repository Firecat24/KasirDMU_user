BoxLayout:
    orientation: 'vertical'

    MDToolbar:
        title: "Data Obat"
        left_action_items: [["menu", lambda x: app.navigation_draw()]]
        elevation: 10
    
    MDRaisedButton:
        text: "Select All"
        size_hint: None, None
        size: "200dp", "48dp"
        pos_hint: {"center_x": 0.5}
        on_release: app.select_all_checkbox()

    MDDataTable:
        id: data_table
        size_hint: None, None
        size: "600dp", "400dp"
        column_data: [
            ("ID", dp(30)),
            ("Jenis", dp(30)),
            ("PLU", dp(30)),
            ("Nama Produk", dp(50)),
            ("Select", dp(30))  # Kolom checkbox
        ]
        row_data: [
            ("1", "Jenis 1", "123", "Obat A", "True"),
            ("2", "Jenis 2", "124", "Obat B", "False"),
            ("3", "Jenis 3", "125", "Obat C", "True")
        ]
